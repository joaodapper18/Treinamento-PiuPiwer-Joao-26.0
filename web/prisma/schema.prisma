datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- MODELOS DO SISTEMA (PIUPIWER) ---

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String    @unique
  username      String    @unique
  password      String?   // Opcional se usar login social, obrigatório para e-mail/senha
  emailVerified Boolean?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relacionamentos
  pius          Piu[]
  sessions      Session[]
  accounts      Account[]

  role          Role      @default(USER)

  @@map("user")
}

model Piu {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  text      String
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@map("piu")
}

enum Role {
  USER
  ADMIN
}

// --- CONFIGURAÇÕES DO BETTER AUTH (NÃO MEXER) ---

model Session {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(auto()) @map("_id") @db.ObjectId
  accountId             String
  providerId            String
  userId                String    @db.ObjectId
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// --- MODELOS EXTRAS (CURSOS/AULAS) ---

model Curso {
  id                   String                    @id @default(auto()) @map("_id") @db.ObjectId
  name                 String
  descricao            String
  slug                 String                    @unique
  materiasRelacionadas CursoMateriaRelacionada[]
}

model CursoMateriaRelacionada {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  curso     Curso   @relation(fields: [cursoId], references: [id])
  cursoId   String  @db.ObjectId
  materia   Materia @relation(fields: [materiaId], references: [id])
  materiaId String  @db.ObjectId

  @@unique([cursoId, materiaId])
}

model Materia {
  id                 String                    @id @default(auto()) @map("_id") @db.ObjectId
  name               String
  descricao          String
  cor                String
  slug               String                    @unique
  cursosRelacionados CursoMateriaRelacionada[]
}

model Licao {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  descricao String
  archived  Boolean? @default(false)
}